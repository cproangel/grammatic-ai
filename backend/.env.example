# TilshunosAI Backend

# ═══════════════════════════════════════════════════════════════
#  Вариант A: Vertex AI (service account JSON) — для продакшена
# ═══════════════════════════════════════════════════════════════
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION=us-central1
# Содержимое JSON-файла сервис-аккаунта одной строкой (с \n в приватном ключе)
GOOGLE_APPLICATION_CREDENTIALS_JSON=""

# ═══════════════════════════════════════════════════════════════
#  Вариант B: Gemini Developer API — простой ключ из AI Studio
#  (берётся здесь: https://aistudio.google.com/apikey)
# ═══════════════════════════════════════════════════════════════
GEMINI_API_KEY=""

# Модель (оба режима): gemini-3-flash-preview | gemini-3.1-pro-preview | gemini-2.5-flash
GEMINI_MODEL=gemini-3-flash-preview

# CORS — "*" для dev, список доменов через запятую для прода
# пример: ALLOWED_ORIGINS=https://grammatic.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=*
